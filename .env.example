# =============================================================================
# Ethereum Dev Kit — Environment Variables Template
# =============================================================================
# This file is safe to commit. It contains no real credentials.
# Copy it to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Ethereum Node RPC ---
ETH_RPC_ENDPOINT=http://localhost:8001

# --- Ethereum Network ---
# Options: mainnet | sepolia | holesky
ETH_NETWORK=sepolia

# --- Ethereum Chain ID ---
# mainnet: 1 | sepolia: 11155111 | holesky: 17000
ETH_CHAIN_ID=11155111

